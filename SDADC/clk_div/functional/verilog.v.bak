//Verilog HDL for "SDADC", "clk_div" "functional"


module clk_div (clk,rst_n,clk64,clk256);
	input clk,rst_n;
	output reg clk64,clk256;

reg [4:0] cnt64;
reg [6:0] cnt256;

always@(posedge clk,negedge rst_n)
begin
	if(!rst_n) begin
		cnt64<=0;
		cnt256<=0;
	end
	else begin
		cnt64<=cnt64+1;
		cnt256<=cnt256+1;
	end
end

always@(posedge clk,negedge rst_n)
begin
	if(!rst_n) begin
		clk64<=0;
		clk256<=0;
	end
	else begin
		clk64<=(cnt64 == 31)?~clk64:clk64;
		clk256<=(cnt256 == 127)?~clk256:clk256;
end


endmodule
